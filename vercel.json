{
  "buildCommand": "pnpm install && pnpm run build",
  "outputDirectory": "artifacts/money-tracker/dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
